---
import { site } from "../data/site";
---

<section class="hero shell" aria-labelledby="hero-name">
  <div class="hero__grid">
    <div class="hero__intro" data-reveal>
      <p class="hero__avail"><span class="pulse"></span>{site.available}</p>
      <h1 class="hero__name" id="hero-name">
        Szymon<br />Chirowski<span class="accent">.</span>
      </h1>
      <p class="hero__role">{site.role} · {site.tagline}</p>
      <p class="hero__lead">
        I'm a Data Science & AI student who likes building ML systems end to end — from a
        notebook experiment to something you can actually <strong>deploy, monitor and
        trust</strong>. MLOps is the part I keep gravitating toward.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href={site.cv} download>
          Download CV <span class="arrow">↓</span>
        </a>
        <a class="btn btn--ghost" href={`mailto:${site.email}`}>
          Get in touch <span class="arrow">↗</span>
        </a>
      </div>
    </div>

    <div class="hero__media" data-reveal>
      <figure class="hero__photo">
        <img src="/profile.jpg" width="900" height="1200"
          alt={`${site.name}, ${site.role}`} />
      </figure>
      <div class="hero__badge">
        <b>Breda, Netherlands</b><br />
        Final-year Data Science & AI student
      </div>
    </div>
  </div>
</section>
